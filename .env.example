# ---------- Backend ----------
APP_NAME="Data Web Foundation API"
APP_ENV="development"
API_V1_PREFIX="/api/v1"
AUTO_CREATE_TABLES=true

# Banco local padrao (SQLite) para desenvolvimento sem setup extra
DATABASE_URL="sqlite:///./dev.db"

# Opcao para ambiente real (PostgreSQL/Supabase):
# DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/analytics_db"

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# API externa para analise (opcional)
EXTERNAL_API_URL="https://example.com/metrics"
EXTERNAL_API_TIMEOUT_SECONDS=8

# Supabase (banco/auth gerenciado)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ---------- Frontend ----------
# Base da API para Next.js server-side fetch
API_BASE_URL="http://127.0.0.1:8000/api/v1"
NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:8000/api/v1"

# Caso o frontend precise usar Supabase JS no futuro:
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
